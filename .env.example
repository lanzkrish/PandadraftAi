# ==========================================
# AutoDraft AI - Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values

# --- Environment ---
# Set to "production" on Render, leave blank for local dev
NODE_ENV=
# Your Render URL (e.g. https://autodraft-ai.onrender.com) — leave blank for local
APP_URL=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- LinkedIn OAuth ---
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback
# Organization/Page ID for posting to a company page (leave empty for personal profile)
# Find it: LinkedIn page URL → linkedin.com/company/YOUR-PAGE → Admin view → URL has the numeric ID
LINKEDIN_ORG_ID=
# Paste the full token JSON here for persistence on Render (logged after first OAuth)
LINKEDIN_TOKENS=

# --- Scheduler ---
# Cron expression for daily post (default: 9:00 AM)
CRON_SCHEDULE=0 9 * * *
# Timezone (default: Asia/Kolkata)
CRON_TIMEZONE=Asia/Kolkata

# --- Server ---
PORT=3000

# --- Content Preferences ---
# Comma-separated categories (leave empty for AI to decide)
CONTENT_CATEGORIES=
# Tone: professional, casual, thought-leadership, storytelling
CONTENT_TONE=professional
